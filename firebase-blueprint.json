{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "notificationsEnabled": { "type": "boolean" },
        "newsletterSubscribed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "SavedProject": {
      "title": "Saved Project",
      "description": "A project saved by the user",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectTitle": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "projectTitle", "savedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/savedProjects/{projectId}": {
      "schema": "SavedProject",
      "description": "Projects saved by the user"
    }
  }
}
